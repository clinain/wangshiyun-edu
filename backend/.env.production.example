# ============================================
# 网师云 - 生产环境配置文件模板
# ============================================
# 部署前将此文件复制为 .env.production 并填入真实密钥
# 命令: cp .env.production.example .env.production

# 应用配置
NODE_ENV=production
PORT=3003
APP_NAME=wangshiyun

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wangshiyun
DB_USER=wangshiyun_app
DB_PASSWORD=请替换为强密码_至少16位字符
DB_DIALECT=mysql
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ============================================
# JWT 配置（⚠️ 必须修改为随机强密钥）
# ============================================
JWT_SECRET=请替换为随机生成的64位字符串_可用openssl_rand_hex_64生成
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AI 服务配置
# ============================================

# 主 AI 提供商（zhipu / volcengine / dashscope）
AI_PRIMARY_PROVIDER=volcengine

# --- 火山引擎 ARK（主 AI，PPT 生成专用）---
VOLCENGINE_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLCENGINE_API_KEY=请替换为你的火山引擎API密钥
VOLCENGINE_SECRET_KEY=
VOLCENGINE_MODEL=doubao-1-5-pro-32k-250115
VOLCENGINE_MAX_TOKENS=8000
VOLCENGINE_AUTH_TYPE=bearer

# --- 智谱 GLM（备用 AI）---
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_API_KEY=请替换为你的智谱API密钥
ZHIPU_MODEL=glm-4-flash
ZHIPU_MAX_TOKENS=8000
ZHIPU_TEMPERATURE=0.7

# --- 阿里云 DashScope（备用 AI）---
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
DASHSCOPE_API_KEY=请替换为你的阿里云API密钥
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MAX_TOKENS=8000
DASHSCOPE_TEMPERATURE=0.7

# --- 腾讯混元（可选）---
TENCENT_API_URL=https://api.tencent.com/v1/chat/completions
TENCENT_API_KEY=
TENCENT_SECRET_KEY=
TENCENT_MODEL=hunyuan-lite
TENCENT_MAX_TOKENS=8000

# --- 百度文心一言（可选）---
BAIDU_API_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat/completions
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL=ernie-3.5-turbo
BAIDU_MAX_TOKENS=8000

# --- 豆包（可选）---
DOUBAO_API_URL=https://api.doubao.com/v1/chat/completions
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-3
DOUBAO_MAX_TOKENS=8000

# --- 零一万物（可选）---
YI_API_URL=https://api.lingyiwanwu.com/v1/chat/completions
YI_API_KEY=
YI_MODEL=yi-34b-chat
YI_MAX_TOKENS=8000

# ============================================
# Unsplash 图片搜索（可选，PPT 配图用）
# ============================================
# 获取地址：https://unsplash.com/developers（免费，50次/小时）
UNSLASH_ACCESS_KEY=

# ============================================
# CORS 配置（⚠️ 生产环境必须指定具体域名）
# ============================================
CORS_ORIGIN=https://你的域名.com

# ============================================
# 速率限制
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log

# ============================================
# 文件上传配置
# ============================================
UPLOAD_MAX_SIZE=52428800
