# 应用配置
NODE_ENV=development
PORT=3001
APP_NAME=wangshiyun

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wangshiyun
DB_USER=root
DB_PASSWORD=root
DB_DIALECT=mysql
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI服务主提供商配置（优先使用，可选值：zhipu/dashscope/volcengine 等）
AI_PRIMARY_PROVIDER=zhipu

# 智谱GLM-4-Flash AI API配置
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash
ZHIPU_MAX_TOKENS=8000
ZHIPU_TEMPERATURE=0.7

# 阿里云DashScope AI API配置（可选）
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MAX_TOKENS=8000

# 火山引擎AI API配置（支持ARK平台API Key直连）
VOLCENGINE_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_SECRET_KEY=
VOLCENGINE_MODEL=doubao-1-5-pro-32k-250115
VOLCENGINE_MAX_TOKENS=8000
VOLCENGINE_AUTH_TYPE=bearer

# CORS配置
CORS_ORIGIN=http://localhost:8080

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 日志配置
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log

# 上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Redis配置（可选，用于缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 邮件配置（可选，用于发送验证邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@wangshiyun.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@wangshiyun.com